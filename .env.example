# =============================================================================
# Phase 1 — Firebase environment variables (template only)
# =============================================================================
#
# Copy this file to `.env` in the project root and fill in values from:
#   Firebase Console → Project settings → Your apps → Web app config
#
# Vite embeds these at BUILD time (vite.config.ts → __FIREBASE_CONFIG__).
# For production: set the same keys locally before `npm run deploy`, or in CI.
#
# NEVER commit `.env` with real keys — it is gitignored.
#
# All six fields are required — build fails if any is missing.
# =============================================================================

# Web API key (restrict HTTP referrers in Google Cloud Console for production)
VITE_FIREBASE_API_KEY=

# Auth domain — typically {projectId}.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=

# Firebase / Google Cloud project id
VITE_FIREBASE_PROJECT_ID=

# Storage bucket — typically {projectId}.firebasestorage.app
VITE_FIREBASE_STORAGE_BUCKET=

# Messaging sender id (numeric — easy to omit by mistake; build validates this)
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Web app id from Firebase Console
VITE_FIREBASE_APP_ID=
